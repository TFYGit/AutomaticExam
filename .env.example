# Brevo SMTP 账号（你注册 Brevo 时的邮箱）
SMTP_USER=your@email.com

# Brevo SMTP 密码（在 Brevo 控制台 SMTP & API → SMTP 里生成）
SMTP_PASS=your-brevo-smtp-password

# 发件人显示名和邮箱（必须和 SMTP_USER 一致）
FROM_EMAIL=考试系统 <your@email.com>

# 收件人邮箱，多个用英文逗号分隔
TO_EMAIL=person1@example.com,person2@example.com,person3@example.com

# Vercel 部署地址（不含末尾斜杠）
APP_URL=https://your-app.vercel.app

# 用于签名答案链接的密钥（任意随机字符串，越长越好）
ANSWER_SECRET=change-this-to-a-long-random-string-abc123

# 用于 GitHub Actions 调用 API 的密钥（任意随机字符串）
CRON_SECRET=change-this-to-another-random-string-xyz789
