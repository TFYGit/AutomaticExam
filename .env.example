# Resend API Key — 在 https://resend.com/api-keys 获取
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 发件邮箱（格式如下，yourdomain.com 换成你在 Resend 验证的域名）
FROM_EMAIL=考试系统 <noreply@yourdomain.com>

# 收件邮箱（你自己的邮箱，接收题目用）
TO_EMAIL=your@email.com

# Vercel 部署地址（不含末尾斜杠，部署后从 Vercel 控制台复制）
APP_URL=https://your-app.vercel.app

# 用于签名答案链接的密钥（任意随机字符串，越长越好）
ANSWER_SECRET=change-this-to-a-long-random-string-abc123

# 用于 GitHub Actions 调用 API 的密钥（任意随机字符串）
CRON_SECRET=change-this-to-another-random-string-xyz789
